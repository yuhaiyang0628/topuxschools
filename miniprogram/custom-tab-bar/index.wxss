.tab-bar { position: relative; width: 100%; border-top: 1rpx solid #dfe8e5; background: #ffffff; box-shadow: 0 -10rpx 28rpx rgba(36, 63, 66, 0.05); }
.tab-safe-area { display: flex; height: 104rpx; padding-bottom: env(safe-area-inset-bottom); }
.tab-item { position: relative; display: flex; flex: 1; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; min-width: 0; color: #77868a; background: transparent; }
.tab-icon { width: 38rpx; height: 38rpx; opacity: 0.55; }
.tab-label { font-size: 21rpx; font-weight: 600; line-height: 1.25; }
.active-mark { position: absolute; top: 9rpx; width: 30rpx; height: 5rpx; border-radius: 999rpx; background: transparent; }
.tab-item.active { color: #0b6276; }
.tab-item.active .tab-icon { opacity: 1; }
.tab-item.active .active-mark { background: #0b8aa0; }
