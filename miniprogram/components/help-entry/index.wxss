.help-entry { display: inline-flex; align-items: center; justify-content: center; gap: 7rpx; min-width: 108rpx; height: 58rpx; margin: 0; padding: 0 16rpx; color: #0b6276; border: 1rpx solid #b9d7d8; border-radius: 999rpx; background: rgba(255, 255, 255, 0.9); font-size: 22rpx; font-weight: 650; line-height: 58rpx; box-sizing: border-box; }
.help-mark { display: inline-flex; align-items: center; justify-content: center; width: 26rpx; height: 26rpx; color: #ffffff; border-radius: 50%; background: #0b8aa0; font-size: 19rpx; line-height: 26rpx; }
