.notes-page {
  padding-top: 44rpx;
}

.page-title-row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.page-title-row .page-title { min-width: 0; flex: 1; }

.submission-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-top: 30rpx;
  padding: 22rpx;
  color: #0b6276;
  text-align: left;
  border: 1rpx solid #b8d7d5;
  border-radius: 6rpx;
  background: #f2fbfa;
  font-size: 25rpx;
  font-weight: 650;
  box-sizing: border-box;
}

.submission-entry text:last-child { color: #e36546; }

.article-feed {
  margin-top: 40rpx;
}

.article-entry {
  display: block;
  width: 100%;
  padding: 38rpx 0 42rpx;
  color: #17252b;
  text-align: left;
  background: transparent;
  border-bottom: 1rpx solid #d8e2df;
}

.entry-meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  color: #67777c;
  font-size: 22rpx;
}

.entry-meta text:first-child {
  color: #e36546;
}

.entry-title {
  margin-top: 18rpx;
  font-size: 39rpx;
  font-weight: 700;
  line-height: 1.27;
}

.entry-excerpt {
  margin-top: 18rpx;
  color: #55656b;
  font-size: 27rpx;
  line-height: 1.72;
}

.entry-link {
  margin-top: 24rpx;
  color: #0b6276;
  font-size: 24rpx;
  font-weight: 650;
}
