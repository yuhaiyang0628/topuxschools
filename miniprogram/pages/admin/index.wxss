.admin-page {
  padding-top: 62rpx;
  padding-bottom: 80rpx;
}

.admin-title, .editor-title {
  color: #17252b;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.2;
}

.admin-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.new-record-action {
  flex-shrink: 0;
  margin: 0;
  padding: 0 18rpx;
  color: #ffffff;
  border-radius: 6rpx;
  background: #0b6276;
  font-size: 23rpx;
  font-weight: 650;
  line-height: 64rpx;
}

.admin-copy, .field-hint, .record-meta {
  margin-top: 20rpx;
  color: #6b797e;
  font-size: 25rpx;
  line-height: 1.65;
}

.collection-tabs {
  margin: 42rpx -32rpx 28rpx;
  white-space: nowrap;
}

.tab-track {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 32rpx;
}

.collection-tab, .icon-action, .close-editor, .admin-entry {
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
}

.collection-tab {
  min-width: 132rpx;
  height: 70rpx;
  color: #52636a;
  border: 1rpx solid #d4dedc;
  font-size: 27rpx;
  line-height: 68rpx;
}

.collection-tab.active {
  color: #ffffff;
  border-color: #0b6276;
  background: #0b6276;
}

.record-list {
  margin-top: 38rpx;
  border-top: 1rpx solid #dce4e2;
}

.admin-search {
  margin-top: 24rpx;
  padding: 0 22rpx;
  border: 1rpx solid #cfdcda;
  border-radius: 6rpx;
  background: #ffffff;
}

.admin-search input {
  height: 82rpx;
  color: #17252b;
  font-size: 28rpx;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #dce4e2;
}

.record-body { min-width: 0; flex: 1; }
.record-title { color: #17252b; font-size: 29rpx; font-weight: 650; line-height: 1.45; }
.record-meta { margin-top: 8rpx; font-size: 21rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.record-actions { display: flex; gap: 10rpx; flex-shrink: 0; }
.icon-action, .close-editor { padding: 0 16rpx; color: #0b6276; border: 1rpx solid #b8d3d7; font-size: 23rpx; line-height: 58rpx; }
.icon-action.muted { color: #7a5350; border-color: #e4c8c4; }

.admin-denied { padding-top: 82rpx; }

.editor-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(23, 37, 43, 0.38);
}

.editor-sheet {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  max-height: 92vh;
  box-sizing: border-box;
  padding: 34rpx 32rpx 72rpx;
  background: #f7faf9;
  border-radius: 10rpx 10rpx 0 0;
}

.editor-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; margin-bottom: 30rpx; }
.editor-title { font-size: 40rpx; }
.form-grid { display: flex; gap: 18rpx; }
.form-grid .form-field { min-width: 0; flex: 1; }
.form-field { margin-top: 22rpx; padding: 22rpx; border: 1rpx solid #d9e2e0; background: #ffffff; border-radius: 6rpx; }
.field-label { color: #52636a; font-size: 23rpx; font-weight: 650; }
.form-field input, .form-field textarea, .picker-value { min-height: 52rpx; margin-top: 12rpx; color: #17252b; font-size: 28rpx; line-height: 1.5; }
.form-field textarea { width: 100%; }
.picker-value { padding-top: 2rpx; }
.switch-field { display: flex; align-items: center; justify-content: space-between; }
.field-hint { margin-top: 6rpx; font-size: 20rpx; }
.method-option { display: inline-block; margin: 18rpx 24rpx 0 0; color: #304349; font-size: 25rpx; }
.save-button { margin-top: 42rpx; }

.school-editor {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #cddcda;
  border-radius: 6rpx;
  background: #ffffff;
}

.school-editor-note {
  color: #63737a;
  font-size: 22rpx;
  line-height: 1.6;
}

.school-editor-head, .school-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.school-editor-head {
  margin-top: 26rpx;
  color: #6a7b80;
  font-size: 22rpx;
}

.school-row { margin-top: 16rpx; }
.school-editor-head view:first-child, .school-input-wrap { min-width: 0; flex: 1; }
.school-editor-head view:nth-child(2) { width: 100rpx; }
.school-editor-head view:nth-child(3) { width: 76rpx; }
.school-input-wrap input { height: 68rpx; padding: 0 16rpx; border: 1rpx solid #c8d5d3; border-radius: 4rpx; color: #17252b; font-size: 25rpx; }
.final-row .school-input-wrap input { border-color: #0b8aa0; }
.final-label { margin-top: 8rpx; color: #0b6276; font-size: 19rpx; }
.school-row switch { width: 100rpx; flex-shrink: 0; }
.remove-school, .locked-school { width: 64rpx; height: 64rpx; margin: 0; padding: 0; color: #ffffff; border-radius: 50%; background: #d85c50; font-size: 25rpx; line-height: 64rpx; text-align: center; flex-shrink: 0; }
.locked-school { color: #75858a; border-radius: 0; background: transparent; font-size: 19rpx; }
.add-school { width: 100%; height: 72rpx; margin-top: 28rpx; color: #0b6276; border: 1rpx solid #9bc6cc; border-radius: 6rpx; background: #f7fbfb; font-size: 25rpx; line-height: 70rpx; }
