<view wx:if="{{caseStudy}}" class="detail-page">
  <view class="detail-hero">
    <view class="eyebrow">录取案例 · {{caseStudy.year}}</view>
    <view class="detail-title">{{caseStudy.title}}</view>
    <view class="detail-school">{{caseStudy.selected.school.schoolCn}}</view>
    <view class="detail-school-en">{{caseStudy.selected.school.school}} · {{caseStudy.selected.program.program}}</view>
    <view class="outcome-tags">
      <text class="outcome-tag {{item.status}}" wx:for="{{caseStudy.outcomes}}" wx:key="label">{{item.label}}</text>
    </view>
  </view>

  <view class="detail-body">
    <view class="section-label">申请背景</view>
    <view class="fact-grid">
      <view class="fact-item" wx:for="{{facts}}" wx:key="label">
        <text class="fact-label">{{item.label}}</text>
        <text class="fact-value">{{item.value}}</text>
      </view>
    </view>

    <view class="section-label section-space">申请方式</view>
    <view class="method-tags detail-method-tags">
      <text class="method-tag" wx:for="{{caseStudy.applicationMethods}}" wx:key="*this">{{item}}</text>
    </view>

    <view class="section-label section-space">申请结果</view>
    <view class="outcome-tags detail-outcome-tags">
      <text class="outcome-tag {{item.status}}" wx:for="{{caseStudy.outcomes}}" wx:key="label">{{item.label}}</text>
    </view>

    <button class="secondary-action" bindtap="goToContact">有类似问题，先聊聊</button>
  </view>
</view>
