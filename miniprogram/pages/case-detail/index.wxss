.detail-page {
  min-height: 100vh;
  background: #ffffff;
}

.detail-hero {
  padding: 58rpx 30rpx 46rpx;
  background: #edf6ef;
}

.detail-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.24;
}

.detail-school {
  margin-top: 26rpx;
  font-size: 30rpx;
  font-weight: 650;
}

.detail-school-en {
  margin-top: 8rpx;
  color: #5d6f75;
  font-size: 24rpx;
  line-height: 1.5;
}

.outcome-tags, .method-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 22rpx;
}

.outcome-tag, .method-tag {
  padding: 6rpx 13rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.outcome-tag.selected {
  color: #ffffff;
  background: #0d7a4b;
}

.outcome-tag.offer {
  color: #17613d;
  background: #d9f5e1;
}

.outcome-tag.rejected {
  color: #9b3336;
  background: #fde1e0;
}

.outcome-tag.pending {
  color: #5e676b;
  background: #e6eaeb;
}

.method-tag {
  color: #334448;
  background: #eef1f0;
}

.detail-body {
  padding: 42rpx 30rpx 64rpx;
}

.section-label {
  color: #0b6276;
  font-size: 23rpx;
  font-weight: 700;
  letter-spacing: 1.4rpx;
}

.section-space {
  margin-top: 54rpx;
}

.fact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 30rpx 34rpx;
  margin-top: 28rpx;
}

.fact-item {
  display: flex;
  flex-direction: column;
  gap: 9rpx;
}

.fact-label {
  color: #718086;
  font-size: 23rpx;
}

.fact-value {
  color: #23353b;
  font-size: 26rpx;
  line-height: 1.55;
}

.detail-method-tags, .detail-outcome-tags { margin-top: 24rpx; }

.secondary-action {
  width: 100%;
  height: 86rpx;
  margin-top: 54rpx;
  color: #084d60;
  background: #ffffff;
  border: 1rpx solid #a6c9cf;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 86rpx;
}
