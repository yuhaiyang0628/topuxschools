.home-page {
  padding-top: 38rpx;
}

.home-header {
  padding: 12rpx 4rpx 42rpx;
}

.home-title {
  max-width: 640rpx;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.16;
}

.home-title text {
  display: block;
  color: #0b6276;
}

.home-intro {
  margin-top: 22rpx;
  color: #5f7076;
  font-size: 29rpx;
  line-height: 1.72;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 0 -28rpx;
  padding: 28rpx;
  background: #e4f2f2;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-left: 18rpx;
  border-left: 1rpx solid #b9d6d7;
}

.stat-item:first-child {
  padding-left: 0;
  border-left: 0;
}

.stat-number {
  color: #084d60;
  font-size: 42rpx;
  font-weight: 750;
}

.stat-label {
  color: #607178;
  font-size: 22rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 30rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 192rpx;
  padding: 26rpx;
  text-align: left;
  border: 1rpx solid #d5e2df;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.quick-number {
  color: #e36546;
  font-size: 22rpx;
  font-weight: 750;
}

.quick-title {
  margin-top: auto;
  font-size: 33rpx;
  font-weight: 700;
}

.quick-copy {
  margin-top: 7rpx;
  color: #607178;
  font-size: 22rpx;
}

.quick-programs, .quick-notes {
  background: #ffffff;
}

.quick-cases {
  background: #edf6ef;
}

.quick-contact {
  background: #fff0eb;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 54rpx;
}

.section-space {
  margin-top: 62rpx;
}

.program-list, .case-list, .article-list {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.program-card, .case-card, .article-card {
  display: block;
  width: 100%;
  padding: 26rpx;
  color: #17252b;
  text-align: left;
  background: #ffffff;
  border: 1rpx solid #d5e2df;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.card-topline, .article-meta {
  display: flex;
  justify-content: space-between;
  color: #607178;
  font-size: 22rpx;
}

.card-topline text:last-child, .article-meta text:first-child {
  color: #0b6276;
}

.program-name, .case-result, .article-title {
  margin-top: 18rpx;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.3;
}

.program-school, .case-program {
  margin-top: 7rpx;
  color: #607178;
  font-size: 24rpx;
  line-height: 1.5;
}

.program-degree {
  margin-top: 17rpx;
  font-size: 25rpx;
  line-height: 1.5;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 5rpx 12rpx;
  color: #084d60;
  background: #e7f3f4;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.case-summary, .article-excerpt {
  margin-top: 17rpx;
  color: #54656b;
  font-size: 25rpx;
  line-height: 1.65;
}
